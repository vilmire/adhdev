{
  "name": "@adhdev/terminal-mux-core",
  "version": "0.9.29",
  "description": "ADHDev terminal mux core built on session-host and libghostty",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "adhdev",
    "terminal",
    "mux",
    "ghostty",
    "session-host"
  ],
  "author": "vilmire",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@adhdev/ghostty-vt-node": "*",
    "@adhdev/session-host-core": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vilmire/adhdev.git",
    "directory": "packages/terminal-mux-core"
  },
  "homepage": "https://github.com/vilmire/adhdev#readme"
}
