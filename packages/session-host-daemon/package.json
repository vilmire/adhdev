{
  "name": "@adhdev/session-host-daemon",
  "version": "0.8.87",
  "description": "ADHDev local session host daemon \u2014 long-lived session runtime",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "adhdev-sessiond": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "adhdev",
    "session-host",
    "pty",
    "daemon"
  ],
  "author": "vilmire",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@adhdev/ghostty-vt-node": "*",
    "@adhdev/session-host-core": "*",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.2.0-beta.12"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vilmire/adhdev.git",
    "directory": "packages/session-host-daemon"
  },
  "homepage": "https://github.com/vilmire/adhdev#readme"
}
