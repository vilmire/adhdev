{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@adhdev/daemon-core": ["../daemon-core/src/index.ts"],
      "@adhdev/daemon-core/status/normalize": ["../daemon-core/src/status/normalize.ts"]
    },
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "..",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["dist", "node_modules"]
}
