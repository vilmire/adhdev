{
  "name": "@adhdev/daemon-core",
  "version": "0.8.76",
  "description": "ADHDev daemon core \u2014 CDP, IDE detection, providers, command execution",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./status/normalize": {
      "types": "./dist/status/normalize.d.ts",
      "import": "./dist/status/normalize.mjs",
      "require": "./dist/status/normalize.js",
      "default": "./dist/status/normalize.js"
    },
    "./chat/chat-signatures": {
      "types": "./dist/chat/chat-signatures.d.ts",
      "import": "./dist/chat/chat-signatures.mjs",
      "require": "./dist/chat/chat-signatures.js",
      "default": "./dist/chat/chat-signatures.js"
    }
  },
  "scripts": {
    "build": "tsup && npm run build:types",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly --declaration --declarationMap false",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "files": [
    "dist",
    "src",
    "providers"
  ],
  "keywords": [
    "adhdev",
    "daemon",
    "cdp",
    "ide-detection"
  ],
  "author": "vilmire",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@adhdev/session-host-core": "*",
    "@agentclientprotocol/sdk": "^0.16.1",
    "@xterm/xterm": "^6.0.0",
    "chalk": "^5.3.0",
    "chokidar": "^5.0.0",
    "conf": "^13.0.0",
    "node-pty": "^1.2.0-beta.12",
    "ws": "^8.19.0"
  },
  "bundleDependencies": [
    "@adhdev/session-host-core"
  ],
  "optionalDependencies": {
    "@adhdev/ghostty-vt-node": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vilmire/adhdev.git",
    "directory": "packages/daemon-core"
  },
  "homepage": "https://github.com/vilmire/adhdev#readme"
}
