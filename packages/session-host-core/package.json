  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vilmire/adhdev.git",
    "directory": "packages/session-host-core"
  },
  "homepage": "https://github.com/vilmire/adhdev#readme"
}
